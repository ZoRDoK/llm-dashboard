{
  "name": "ai-creds",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node --env-file=.env dist/src/index.js",
    "check": "biome check . && knip && cspell lint 'src/**/*.ts' && gitleaks detect && npm run dupes",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "knip": "knip",
    "spellcheck": "cspell lint 'src/**/*.ts'",
    "secrets": "gitleaks detect --source=.",
    "secrets:full": "gitleaks detect --source=. --verbose",
    "dupes": "jscpd src/",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.7",
    "hono": "^4.6.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@cspell/dict-ru_ru": "^2.3.2",
    "@types/node": "^22.10.0",
    "cspell": "^10.0.0",
    "jscpd": "^4.0.9",
    "knip": "^6.11.0",
    "lefthook": "^2.1.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0"
  }
}
