# MiniMax Token Plan
MINIMAX_API_KEY=mm-your-token-plan-key-here

# Ollama Cloud — API key from ollama.com/settings
OLLAMA_CLOUD_API_KEY=osk-...
# Session cookie for scraping ollama.com/settings (alternative to API key)
# OLLAMA_CLOUD_SESSION_COOKIE=...

# OpenCode Go — API key for usage API
# OPENCODE_GO_API_KEY=...
# Session cookie for scraping opencode.ai/workspace/{id}/go
OPENCODE_GO_SESSION_COOKIE=...
# Workspace ID for opencode.ai usage page
OPENCODE_GO_WORKSPACE_ID=wrk_...

# OpenAI Codex — OAuth access token
OPENAI_CODEX_ACCESS_TOKEN=eyJ...

# Tavily — API key for usage endpoint
TAVILY_API_KEY=tvly-...

# Context7 — API key for library metrics
CONTEXT7_API_KEY=ctx7sk-...
# Comma-separated library IDs to monitor (e.g., /upstash/context7,/owner/repo)
# CONTEXT7_LIBRARY_IDS=...

# Server port (default: 3001)
PORT=3001
